{
  "name": "fluxion-render-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm --filter @heojeongbo/fluxion-worker build && pnpm --filter @heojeongbo/fluxion-render build",
    "dev": "pnpm --filter @heojeongbo/fluxion-render build && pnpm -r --parallel --filter @heojeongbo/fluxion-render --filter vite-demo run dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r run test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "release": "pnpm --filter @heojeongbo/fluxion-render release",
    "release:dry": "pnpm --filter @heojeongbo/fluxion-render release:dry",
    "release:patch": "pnpm --filter @heojeongbo/fluxion-render release:patch",
    "release:minor": "pnpm --filter @heojeongbo/fluxion-render release:minor",
    "release:major": "pnpm --filter @heojeongbo/fluxion-render release:major",
    "release:worker": "pnpm --filter @heojeongbo/fluxion-worker release",
    "release:worker:dry": "pnpm --filter @heojeongbo/fluxion-worker release:dry",
    "release:worker:patch": "pnpm --filter @heojeongbo/fluxion-worker release:patch",
    "release:worker:minor": "pnpm --filter @heojeongbo/fluxion-worker release:minor",
    "release:worker:major": "pnpm --filter @heojeongbo/fluxion-worker release:major"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "typescript": "^5.5.4"
  }
}
